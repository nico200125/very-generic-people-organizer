<Window xmlns="https://github.com/avaloniaui"
        xmlns:vm="using:Organizador.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Organizador.Views.MostrarPersonaWindow"
        x:DataType="vm:MostrarPersonaViewModel"
        Title="Window1">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="Informacion de la Persona" FontSize="18" FontWeight="Bold"/>
        
        <Separator/>
        
        <Label Content="Cedula de Identidad:"/>
        <TextBlock Text="{Binding persona.CI}" FontWeight="Bold"/>
        
        <Label Content="Nombre Completo:"/>
        <TextBlock Text="{Binding persona.Name}" FontSize="16"/>
       
    </StackPanel>
</Window>
