<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Organizador.Views.NuevaPersonaWindow"
        Title="Nueva Persona" Width="350" Height="350"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock Text="CI:" />
        <TextBox Name="CIInput" />
        <TextBlock Text="Nombre:" />
        <TextBox Name="NameInput" />
        <TextBlock Text="Fecha de Nacimiento:" />
        <DatePicker Name="BirthDatePicker" HorizontalAlignment="Stretch"/>
        <TextBlock Text="Telefono:" />
        <TextBox Name="TelefonoInput" />

        <Button Content="Guardar" HorizontalAlignment="Stretch" />
    </StackPanel>
</Window>
